# Learnova LMS Environment Configuration

# PostgreSQL connection URL - jdbc:postgresql://host:port/database?sslmode=require
DB_URL=jdbc:postgresql://localhost:5432/learnova?sslmode=require

# Database credentials
DB_USERNAME=postgres
DB_PASSWORD=change_to_strong_password

# JWT secret key - Generate: openssl rand -base64 256
JWT_SECRET=your_jwt_secret_key_here

# JWT expiration in milliseconds (86400000 = 24 hours)
JWT_EXPIRATION_MS=86400000

# Server port
SERVER_PORT=8080

# CORS allowed origins (comma-separated) — include your frontend URL
cors.allowed-origins=https://learnova-lms-delta.vercel.app

# Active Spring profiles: dev, test, prod
SPRING_PROFILES_ACTIVE=prod

# Admin credentials (MUST BE SET for production — change to secure values)
ADMIN_EMAIL=admin@learnova.io
ADMIN_PASSWORD=secure_password_here
ADMIN_NAME=Administrator
