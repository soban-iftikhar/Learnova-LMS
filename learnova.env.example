# Learnova LMS - Production Environment Variables
# Copy this file to /etc/learnova/learnova.env or export variables in your shell

# ============================================================================
# CRITICAL: Database Configuration - MUST BE SET FOR PRODUCTION
# ============================================================================

# MySQL connection URL (update host and port if needed)
# Format: jdbc:mysql://host:port/database?options
DB_URL=jdbc:mysql://localhost:3306/learnova?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=false

# Database username (created by setup-mysql.sh)
DB_USERNAME=learnova_user

# Database password (CHANGE THIS TO A STRONG PASSWORD)
# Generate secure password: openssl rand -base64 32
DB_PASSWORD=change_this_to_strong_password

# ============================================================================
# CRITICAL: JWT Configuration - MUST BE SET FOR PRODUCTION
# ============================================================================

# JWT Secret Key (CRITICAL: Generate a new one using strong random key)
# This should be a very long, random string (256+ bits recommended)
# Generate with: openssl rand -base64 256
JWT_SECRET=your-very-long-random-secret-key-minimum-256-bits-generate-with-openssl-rand-base64-256

# JWT Expiration in milliseconds (default: 24 hours = 86400000)
JWT_EXPIRATION_MS=86400000

# ============================================================================
# Server Configuration (Optional)
# ============================================================================

# Server port (default: 8080)
SERVER_PORT=8080

# Server context path (optional, default: /api)
# SERVER_SERVLET_CONTEXT_PATH=/api

# ============================================================================
# OAuth2 Configuration (Optional - for future integration)
# ============================================================================

# Google OAuth2 (for future social login feature)
# OAUTH2_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# OAUTH2_GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2 (for future social login feature)
# OAUTH2_GITHUB_CLIENT_ID=your-github-client-id
# OAUTH2_GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================

# Log level: TRACE, DEBUG, INFO, WARN, ERROR
# SPRING_LOG_LEVEL=INFO
# LOGGING_LEVEL_LMS_LEARNOVA=INFO
# LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

# ============================================================================
# Application Profiles (Optional)
# ============================================================================

# Active Spring profiles: dev, test, prod
# SPRING_PROFILES_ACTIVE=prod

# ============================================================================
# JVM Configuration (Optional - set in systemd service or startup script)
# ============================================================================

# JVM Heap Size (in startup command)
# java -Xmx2g -Xms1g -jar Learnova-0.0.1-SNAPSHOT.jar

# ============================================================================
# Production Deployment Instructions
# ============================================================================

# For Linux/Unix SystemD Service:
# 1. Copy this file to /etc/learnova/learnova.env
#    sudo cp learnova.env /etc/learnova/learnova.env
#
# 2. Restrict permissions on env file (important for security)
#    sudo chmod 600 /etc/learnova/learnova.env
#
# 3. Set SystemD to load these variables
#    Create /etc/systemd/system/learnova.service with EnvironmentFile=/etc/learnova/learnova.env
#
# 4. Reload and restart service
#    sudo systemctl daemon-reload
#    sudo systemctl restart learnova

# For Docker Deployment:
# 1. Build with: docker build -t learnova .
#
# 2. Run with: docker run -d \
#      -e DB_URL="jdbc:mysql://mysql:3306/learnova?useSSL=false&serverTimezone=UTC" \
#      -e DB_USERNAME="learnova_user" \
#      -e DB_PASSWORD="password" \
#      -e JWT_SECRET="your-secret" \
#      -e JWT_EXPIRATION_MS="86400000" \
#      -p 8080:8080 \
#      learnova

# For Manual/Direct Execution:
# 1. Export variables: source learnova.env
#
# 2. Run application: java -jar Learnova-0.0.1-SNAPSHOT.jar

# ============================================================================
# Security Best Practices
# ============================================================================

# 1. Change all default passwords and secrets
# 2. Use strong passwords (min 16 chars, with special characters)
# 3. Store secrets in secure location (secrets manager, not in git)
# 4. Enable SSL/TLS for database connections (useSSL=true)
# 5. Enable application HTTPS (configure nginx reverse proxy with SSL)
# 6. Rotate JWT secret periodically
# 7. Restrict database user permissions to only necessary operations
# 8. Monitor logs for suspicious activity
# 9. Keep Java and MySQL updated with security patches
# 10. Implement firewall rules to restrict access

# ============================================================================
# Troubleshooting
# ============================================================================

# Database Connection Issues:
# - Check MySQL is running: sudo systemctl status mysql
# - Test connection: mysql -u DB_USERNAME -p -h localhost -e "SELECT 1;"
# - Verify environment variables: env | grep DB_

# JWT Token Issues:
# - Ensure JWT_SECRET is set and consistent across instances
# - Check token expiration time: JWT_EXPIRATION_MS
# - Verify Authorization header format: "Bearer <token>"

# Application Startup Issues:
# - Check logs: docker logs container_name OR journalctl -u learnova -f
# - Verify all required env vars are set: env | grep -E 'DB_|JWT_'
# - Check if port 8080 is already in use: sudo lsof -i :8080

# ============================================================================
# Database Backup Schedule (Recommended)
# ============================================================================

# Add to crontab for daily backups:
# 0 2 * * * /home/user/learnova-backup.sh

# Backup script content:
# #!/bin/bash
# mysqldump -u $DB_USERNAME -p$DB_PASSWORD -h localhost learnova > \
#   /backups/learnova_$(date +\%Y\%m\%d_\%H\%M\%S).sql
# 
# # Keep last 30 days of backups
# find /backups -name "learnova_*.sql" -mtime +30 -delete
